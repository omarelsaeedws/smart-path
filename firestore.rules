rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------
    // isAdmin() — safe only inside READ rules.
    //   do NOT call inside write rules (causes emulator assertion errors).
    // ------------------------------------
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ===== USERS COLLECTION =====
    match /users/{userId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null;

      // ===== LEARNING PATHS SUBCOLLECTION =====
      match /learningPaths/{pathId} {
        allow read, write: if request.auth != null &&
                              request.auth.uid == userId;
      }
    }

    // ===== COURSES COLLECTION =====
    match /courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== RESOURCES COLLECTION =====
    match /resources/{resourceId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== ROADMAPS COLLECTION (NEW) =====
    // All authenticated users can read roadmaps and their subcollections.
    // Only admins can write (admin enforcement at app layer for emulator compatibility).
    match /roadmaps/{roadmapId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /weeks/{weekId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;

        match /lessons/{lessonId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null;
        }
      }
    }

    // ===== USER PROGRESS COLLECTION (NEW) =====
    // Each user can only read/write their own progress.
    match /userProgress/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /roadmaps/{roadmapId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ===== QUIZ CACHE (NEW) =====
    // Any authenticated user can read quiz cache.
    // Writes come from Firebase Functions (server-side admin SDK — bypasses rules).
    match /quizCache/{lessonId} {
      allow read: if request.auth != null;
      allow write: if false; // Only server (admin SDK) can write
    }

    // ===== APPLICATIONS COLLECTION =====
    // All authenticated users can read applications.
    // Admin enforcement is handled at the application layer (consistent with other collections).
    match /applications/{appId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== CATEGORIES COLLECTION =====
    // All authenticated users can read categories.
    // Admin enforcement is handled at the application layer.
    match /categories/{catId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== RATINGS COLLECTION =====
    match /ratings/{ratingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

  }
}